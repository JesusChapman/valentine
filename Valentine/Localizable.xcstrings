    "This project is and always will be open source, free, and ad-free. You can support the development by making a donation to maintain it over time!.": {
      "extractionState": "manual",
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este proyecto es y siempre será código abierto, libre y sin anuncios, puedes apoyar el desarrollo haciendo un donativo para mantener su desarrollo con el tiempo!."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह प्रोजेक्ट हमेशा ओपन सोर्स, मुफ़्त और विज्ञापन-मुक्त रहेगा। आप इसे समय के साथ बनाए रखने के लिए दान करके विकास का समर्थन कर सकते हैं!।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このプロジェクトは今後も常にオープンソース、無料、広告なしです。長期にわたる開発を維持するために、寄付による支援をお願いします！"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este projeto é e sempre será de código aberto, livre e sem anúncios, você pode apoiar o desenvolvimento fazendo uma doação para mantê-lo ao longo do tempo!."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此项目现在和将来都将是开源、免费且无广告的。您可以通过捐赠来支持开发，以随时间推移维护它！"
          }
        }
      }
    },
