        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइल या फ़ोल्डर चुनें, या प्लेलिस्ट में गाने जोड़ने के लिए अपने फ़ाइल प्रबंधक से\nएप्लिकेशन विंडो में फ़ाइलों को खींचें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルまたはフォルダを選択するか、ファイルマネージャから\nアプリケーションウィンドウにファイルをドラッグして曲をプレイリストに追加します"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecione um arquivo ou pasta, ou arraste arquivos do seu gerenciador de arquivos para\na janela do aplicativo para adicionar músicas à lista de reprodução"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择一个文件或文件夹，或者从文件管理器中将文件拖到\n应用程序窗口中，以将歌曲添加到播放列表"
          }
        }
      }
    },
